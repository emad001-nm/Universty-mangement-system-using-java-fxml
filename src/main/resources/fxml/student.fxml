<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.university.controllers.StudentController"
      spacing="15"
      style="-fx-padding: 20; -fx-background-color: #f0f2f5;">

    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
        <VBox spacing="2">
            <Label text="👨‍🎓 Student Management" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Manage all student records and information" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="10">
            <Button text="🔄 Refresh" onAction="#refreshStudents" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
            <Button text="➕ Add Student" onAction="#showAddStudent" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
            <Button text="✖ Close" onAction="#closeWindow" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
        </HBox>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
        <TextField fx:id="searchField" promptText="🔍 Search students..." HBox.hgrow="ALWAYS" style="-fx-padding: 8 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-font-size: 14px;"/>
        <ComboBox fx:id="filterDept" promptText="All Departments" style="-fx-pref-width: 150; -fx-padding: 8 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd;"/>
        <ComboBox fx:id="filterSemester" promptText="All Semesters" style="-fx-pref-width: 150; -fx-padding: 8 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd;"/>
    </HBox>

    <TableView fx:id="studentTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
        <columns>
            <TableColumn text="#" fx:id="idCol" prefWidth="50" style="-fx-alignment: center;"/>
            <TableColumn text="Unique ID" fx:id="uniqueIdCol" prefWidth="100"/>
            <TableColumn text="Full Name" fx:id="nameCol" prefWidth="150"/>
            <TableColumn text="Email" fx:id="emailCol" prefWidth="180"/>
            <TableColumn text="Roll Number" fx:id="rollCol" prefWidth="100"/>
            <TableColumn text="Department" fx:id="deptCol" prefWidth="120"/>
            <TableColumn text="Semester" fx:id="semesterCol" prefWidth="80" style="-fx-alignment: center;"/>
            <TableColumn text="CGPA" fx:id="cgpaCol" prefWidth="80" style="-fx-alignment: center;"/>
            <TableColumn text="Status" fx:id="statusCol" prefWidth="100" style="-fx-alignment: center;"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER" style="-fx-background-color: white; -fx-padding: 12 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
        <Button text="✏️ Edit" onAction="#editStudent" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
        <Button text="🗑️ Delete" onAction="#deleteStudent" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
        <Button text="📋 View Details" onAction="#viewDetails" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="recordCount" text="Showing 0 records" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
    </HBox>
</VBox>