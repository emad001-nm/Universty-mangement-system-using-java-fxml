<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.university.controllers.LoginController"
      styleClass="login-container"
      alignment="CENTER"
      spacing="20">

    <VBox styleClass="login-box" alignment="CENTER" spacing="15">
        <Label styleClass="login-title" text="🏛️ University Management System"/>
        <Label styleClass="login-subtitle" text="Sign in to access your dashboard"/>

        <VBox spacing="15" alignment="CENTER">
            <TextField fx:id="emailField"
                       styleClass="login-field"
                       promptText="Email Address"/>

            <PasswordField fx:id="passwordField"
                           styleClass="login-field"
                           promptText="Password"/>

            <Button fx:id="loginButton"
                    styleClass="login-button"
                    text="Sign In"
                    onAction="#handleLogin"/>

            <Label fx:id="errorLabel" styleClass="error-label"/>

            <ProgressIndicator fx:id="loadingIndicator"
                               styleClass="loading-indicator"
                               visible="false"/>
        </VBox>

        <Label text="Demo: admin@university.com / admin123"
               style="-fx-text-fill: #95a5a6; -fx-font-size: 11px; -fx-padding: 10 0 0 0;"/>
    </VBox>
</VBox>