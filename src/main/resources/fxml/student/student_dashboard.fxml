<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.university.controllers.StudentDashboardController"
            style="-fx-background-color: #f0f2f5;">

    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 15 20;">
            <HBox spacing="20" alignment="CENTER_LEFT">
                <Label text="🏛️ University Management System" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="15" alignment="CENTER">
                    <VBox alignment="CENTER_RIGHT">
                        <Label fx:id="userLabel" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label fx:id="roleLabel" style="-fx-text-fill: #95a5a6; -fx-font-size: 12px;"/>
                    </VBox>
                    <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 20; -fx-cursor: hand;"/>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <left>
        <VBox spacing="5" style="-fx-background-color: #34495e; -fx-padding: 20; -fx-min-width: 200;">
            <Label text="📋 Navigation" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Separator style="-fx-background-color: rgba(255,255,255,0.1);"/>

            <Button text="📊 Dashboard" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-pref-width: 180; -fx-background-radius: 8;"/>
            <Button text="📚 My Courses" onAction="#showEnrolledCourses" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-padding: 10; -fx-pref-width: 180; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button text="✅ Attendance" onAction="#showAttendance" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-padding: 10; -fx-pref-width: 180; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button text="📝 Results" onAction="#showResults" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-padding: 10; -fx-pref-width: 180; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button text="💰 Fees" onAction="#showFees" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-padding: 10; -fx-pref-width: 180; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button text="📅 Schedule" onAction="#showSchedule" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-padding: 10; -fx-pref-width: 180; -fx-background-radius: 8; -fx-cursor: hand;"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Label text="v2.0.0" style="-fx-text-fill: rgba(255,255,255,0.3); -fx-font-size: 11px;"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #f0f2f5;">
            <Label fx:id="welcomeLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <HBox spacing="20">
                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-min-width: 150; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 3);">
                    <Label fx:id="studentName" text="-" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="Name" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-min-width: 150; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 3);">
                    <Label fx:id="rollNumber" text="-" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="Roll Number" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-min-width: 150; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 3);">
                    <Label fx:id="semester" text="-" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="Semester" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                </VBox>
            </HBox>

            <HBox spacing="20">
                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-min-width: 150; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 3);">
                    <Label fx:id="cgpa" text="0.00" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="CGPA" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-min-width: 150; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 3);">
                    <Label fx:id="totalCredits" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="Credits" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-min-width: 150; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 3);">
                    <Label fx:id="attendancePercentage" text="0%" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="Attendance" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>