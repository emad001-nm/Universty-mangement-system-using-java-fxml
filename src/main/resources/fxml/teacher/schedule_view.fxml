<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      spacing="20"
      alignment="CENTER"
      style="-fx-padding: 30; -fx-background-color: #f0f2f5;">

    <Label text="📅 Class Schedule" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    <Label text="View your weekly class schedule" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>

    <VBox spacing="15" alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 30; -fx-min-width: 400; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 3);">
        <Label text="Schedule view coming soon!" style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d;"/>
    </VBox>
</VBox>