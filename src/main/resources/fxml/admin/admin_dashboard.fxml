<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.university.controllers.AdminDashboardController"
            style="-fx-background-color: #f0f2f5;">

    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 15 20;">
            <HBox spacing="20" alignment="CENTER_LEFT">
                <Label text="🏛️ University Management System" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="15" alignment="CENTER">
                    <VBox alignment="CENTER_RIGHT">
                        <Label fx:id="userLabel" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <Label fx:id="roleLabel" style="-fx-text-fill: #95a5a6; -fx-font-size: 12px;"/>
                    </VBox>
                    <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 20; -fx-cursor: hand;"/>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <left>
        <VBox spacing="5" style="-fx-background-color: #34495e; -fx-padding: 20; -fx-min-width: 200;">
            <Label text="📋 Navigation" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Separator style="-fx-background-color: rgba(255,255,255,0.1);"/>

            <Button text="📊 Dashboard" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-pref-width: 180; -fx-background-radius: 8;"/>
            <Button text="👥 Users" onAction="#showUserManagement" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-padding: 10; -fx-pref-width: 180; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button text="🏢 Departments" onAction="#showDepartmentManagement" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-padding: 10; -fx-pref-width: 180; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button text="📚 Courses" onAction="#showCourseManagement" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-padding: 10; -fx-pref-width: 180; -fx-background-radius: 8; -fx-cursor: hand;"/>
            <Button text="📈 Reports" onAction="#showReports" style="-fx-background-color: transparent; -fx-text-fill: #bdc3c7; -fx-padding: 10; -fx-pref-width: 180; -fx-background-radius: 8; -fx-cursor: hand;"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Label text="v2.0.0" style="-fx-text-fill: rgba(255,255,255,0.3); -fx-font-size: 11px;"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #f0f2f5;">
            <Label fx:id="welcomeLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <HBox spacing="20">
                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-min-width: 150; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 3);">
                    <Label fx:id="totalStudents" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="Total Students" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-min-width: 150; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 3);">
                    <Label fx:id="totalTeachers" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="Total Teachers" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-min-width: 150; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 3);">
                    <Label fx:id="totalCourses" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="Total Courses" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-min-width: 150; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 3);">
                    <Label fx:id="totalDepartments" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="Departments" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                </VBox>
            </HBox>

            <HBox spacing="20">
                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-min-width: 150; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 3);">
                    <Label fx:id="pendingFees" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="Pending Fees" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-min-width: 150; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 3);">
                    <Label fx:id="todayAttendance" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="Today's Attendance" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>