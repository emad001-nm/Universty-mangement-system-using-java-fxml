<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.university.controllers.Admin.CourseManagementController"
      spacing="15"
      style="-fx-padding: 20; -fx-background-color: #f0f2f5;">

    <!-- Header -->
    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
        <VBox spacing="2">
            <Label text="📚 Course Management" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Manage all courses and assign teachers" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="10">
            <Button text="🔄 Refresh" onAction="#refreshCourses" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
            <Button text="➕ Add Course" onAction="#addCourse" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
        </HBox>
    </HBox>

    <!-- Search -->
    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
        <TextField fx:id="searchField" promptText="🔍 Search courses..." HBox.hgrow="ALWAYS" style="-fx-padding: 8 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-font-size: 14px;"/>
        <ComboBox fx:id="filterDeptCombo" promptText="All Departments" style="-fx-pref-width: 180; -fx-padding: 8 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd;"/>
    </HBox>

    <!-- Course Table -->
    <TableView fx:id="courseTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
        <columns>
            <TableColumn text="ID" fx:id="courseIdCol" prefWidth="50" style="-fx-alignment: center;"/>
            <TableColumn text="Code" fx:id="courseCodeCol" prefWidth="100"/>
            <TableColumn text="Course Name" fx:id="courseNameCol" prefWidth="200"/>
            <TableColumn text="Credits" fx:id="courseCreditsCol" prefWidth="80" style="-fx-alignment: center;"/>
            <TableColumn text="Department" fx:id="courseDeptCol" prefWidth="150"/>
            <TableColumn text="Teacher" fx:id="courseTeacherCol" prefWidth="150"/>
            <TableColumn text="Students" fx:id="courseStudentsCol" prefWidth="80" style="-fx-alignment: center;"/>
        </columns>
    </TableView>

    <!-- Action Buttons -->
    <HBox spacing="10" alignment="CENTER" style="-fx-background-color: white; -fx-padding: 12 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
        <Button text="✏️ Edit" onAction="#editCourse" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
        <Button text="👨‍🏫 Assign Teacher" onAction="#assignTeacher" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
        <Button text="🗑️ Delete" onAction="#deleteCourse" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="recordCount" text="Showing 0 records" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
    </HBox>
</VBox>