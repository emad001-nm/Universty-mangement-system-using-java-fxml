<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.university.controllers.Admin.FeeManagementController"
      spacing="15"
      style="-fx-padding: 20; -fx-background-color: #f0f2f5;">

    <!-- Header -->
    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
        <VBox spacing="2">
            <Label text="💰 Fee Management" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Manage student fees and payments" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="10">
            <Button text="🔄 Refresh" onAction="#refreshFees" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
            <Button text="➕ Add Fee" onAction="#addFee" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
        </HBox>
    </HBox>

    <!-- Search and Filter -->
    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
        <TextField fx:id="searchField" promptText="🔍 Search fees..." HBox.hgrow="ALWAYS" style="-fx-padding: 8 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-font-size: 14px;"/>
        <ComboBox fx:id="filterStatusCombo" promptText="All Status" style="-fx-pref-width: 150; -fx-padding: 8 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd;"/>
    </HBox>

    <!-- Fee Table -->
    <TableView fx:id="feeTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
        <columns>
            <TableColumn text="ID" fx:id="feeIdCol" prefWidth="50" style="-fx-alignment: center;"/>
            <TableColumn text="Student" fx:id="feeStudentCol" prefWidth="200"/>
            <TableColumn text="Semester" fx:id="feeSemesterCol" prefWidth="80" style="-fx-alignment: center;"/>
            <TableColumn text="Total Amount" fx:id="feeTotalCol" prefWidth="120" style="-fx-alignment: center-right;"/>
            <TableColumn text="Paid Amount" fx:id="feePaidCol" prefWidth="120" style="-fx-alignment: center-right;"/>
            <TableColumn text="Due Amount" fx:id="feeDueCol" prefWidth="120" style="-fx-alignment: center-right;"/>
            <TableColumn text="Status" fx:id="feeStatusCol" prefWidth="120" style="-fx-alignment: center;"/>
        </columns>
    </TableView>

    <!-- Action Buttons -->
    <HBox spacing="10" alignment="CENTER" style="-fx-background-color: white; -fx-padding: 12 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
        <Button text="💰 Mark Paid" onAction="#markFeePaid" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
        <Button text="📝 Record Payment" onAction="#recordPayment" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="recordCount" text="Showing 0 records" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
    </HBox>
</VBox>