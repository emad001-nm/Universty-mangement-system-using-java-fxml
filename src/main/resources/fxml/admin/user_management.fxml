<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.university.controllers.Admin.UserManagementController"
      spacing="15"
      style="-fx-padding: 20; -fx-background-color: #f0f2f5;">

    <!-- Header -->
    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
        <VBox spacing="2">
            <Label text="👥 User Management" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Manage all users in the system" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="10">
            <Button text="🔄 Refresh" onAction="#refreshUsers" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
            <Button text="➕ Add User" onAction="#addUser" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
        </HBox>
    </HBox>

    <!-- Search and Filter -->
    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
        <TextField fx:id="searchField" promptText="🔍 Search users..." HBox.hgrow="ALWAYS" style="-fx-padding: 8 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-font-size: 14px;"/>
        <ComboBox fx:id="filterRoleCombo" promptText="All Roles" style="-fx-pref-width: 150; -fx-padding: 8 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd;"/>
        <ComboBox fx:id="filterStatusCombo" promptText="All Status" style="-fx-pref-width: 150; -fx-padding: 8 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd;"/>
    </HBox>

    <!-- User Table -->
    <TableView fx:id="userTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
        <columns>
            <TableColumn text="ID" fx:id="userIdCol" prefWidth="50" style="-fx-alignment: center;"/>
            <TableColumn text="Unique ID" fx:id="userUniqueIdCol" prefWidth="100"/>
            <TableColumn text="Full Name" fx:id="userFullNameCol" prefWidth="150"/>
            <TableColumn text="Email" fx:id="userEmailCol" prefWidth="200"/>
            <TableColumn text="Role" fx:id="userRoleCol" prefWidth="100" style="-fx-alignment: center;"/>
            <TableColumn text="Status" fx:id="userStatusCol" prefWidth="100" style="-fx-alignment: center;"/>
        </columns>
    </TableView>

    <!-- Action Buttons -->
    <HBox spacing="10" alignment="CENTER" style="-fx-background-color: white; -fx-padding: 12 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
        <Button text="✏️ Edit" onAction="#editUser" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
        <Button text="🔓 Activate" onAction="#activateUser" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
        <Button text="🔒 Deactivate" onAction="#deactivateUser" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
        <Button text="🗑️ Delete" onAction="#deleteUser" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 18; -fx-background-radius: 20; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="recordCount" text="Showing 0 records" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
    </HBox>
</VBox>