<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.university.controllers.Admin.DashboardViewController"
      spacing="20"
      style="-fx-padding: 30; -fx-background-color: #f0f2f5;">

    <Label fx:id="welcomeLabel" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
    <Label text="Here's your system overview" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d; -fx-padding: 0 0 10 0;"/>

    <HBox spacing="20">
        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20 25; -fx-min-width: 160; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
            <Label fx:id="totalStudents" text="0" style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
            <Label text="👨‍🎓 Total Students" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
        </VBox>

        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20 25; -fx-min-width: 160; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
            <Label fx:id="totalTeachers" text="0" style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;"/>
            <Label text="👨‍🏫 Total Teachers" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
        </VBox>

        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20 25; -fx-min-width: 160; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
            <Label fx:id="totalCourses" text="0" style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
            <Label text="📚 Total Courses" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
        </VBox>

        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20 25; -fx-min-width: 160; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
            <Label fx:id="totalDepartments" text="0" style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #9b59b6;"/>
            <Label text="🏢 Departments" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
        </VBox>
    </HBox>

    <HBox spacing="20">
        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20 25; -fx-min-width: 160; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
            <Label fx:id="pendingFees" text="0" style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
            <Label text="💰 Pending Fees" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
        </VBox>

        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20 25; -fx-min-width: 160; -fx-alignment: center; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
            <Label fx:id="todayAttendance" text="0" style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #1abc9c;"/>
            <Label text="✅ Today's Attendance" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
        </VBox>

        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20 25; -fx-min-width: 250; -fx-alignment: center-left; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 3);">
            <Label text="📋 Recent Activities" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-padding: 0 0 5 0;"/>
            <Label fx:id="recentActivities" text="No recent activities" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
        </VBox>
    </HBox>
</VBox>