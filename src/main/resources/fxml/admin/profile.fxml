<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.university.controllers.Admin.ProfileController"
      spacing="20"
      alignment="CENTER"
      style="-fx-padding: 30; -fx-background-color: #f0f2f5;">

    <Label text="👤 My Profile" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 30; -fx-min-width: 450; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 3);">
        <Label text="User Profile" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Separator style="-fx-padding: 10 0;"/>

        <GridPane hgap="20" vgap="12">
            <Label text="Full Name:" style="-fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <Label fx:id="profileName" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Email:" style="-fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <Label fx:id="profileEmail" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Role:" style="-fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <Label fx:id="profileRole" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Unique ID:" style="-fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <Label fx:id="profileUniqueId" text="-" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="Phone:" style="-fx-font-weight: bold;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <Label fx:id="profilePhone" text="-" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <Label text="Gender:" style="-fx-font-weight: bold;" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <Label fx:id="profileGender" text="-" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <Label text="Address:" style="-fx-font-weight: bold;" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <Label fx:id="profileAddress" text="-" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
        </GridPane>

        <Separator style="-fx-padding: 15 0;"/>

        <HBox spacing="15" alignment="CENTER">
            <Button text="🔑 Change Password" onAction="#handleChangePassword"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 20; -fx-cursor: hand;"/>
            <Button text="✏️ Edit Profile" onAction="#handleEditProfile"
                    style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 20; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
</VBox>